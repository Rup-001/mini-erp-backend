{
  "info": {
    "name": "Mini ERP API",
    "_postman_id": "mini-erp-api-collection",
    "description": "Complete API collection for Mini ERP – Inventory & Sales Management System.\n\n## Setup\n1. Import this collection into Postman\n2. Run **Auth → Login (Admin)** first — token is auto-saved\n3. Use other requests (they use `{{accessToken}}` automatically)\n\n## Demo Credentials\n| Role | Email | Password |\n|------|-------|----------|\n| Admin | admin@mini-erp.com | Admin@123 |\n| Manager | manager@mini-erp.com | Manager@123 |\n| Employee | employee@mini-erp.com | Employee@123 |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "saleId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "    pm.test('Login successful', () => pm.expect(json.success).to.be.true);",
                  "    pm.test('Token saved', () => pm.expect(json.data.accessToken).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@mini-erp.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login (Manager)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@mini-erp.com\",\n  \"password\": \"Manager@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login (Employee)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"employee@mini-erp.com\",\n  \"password\": \"Employee@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.data.results && json.data.results.length > 0) {",
                  "        pm.collectionVariables.set('productId', json.data.results[0]._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "search", "value": "", "disabled": true },
                { "key": "category", "value": "Electronics", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sortBy", "value": "sellingPrice:desc", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?search=usb&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "search", "value": "usb" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Demo Product", "type": "text" },
                { "key": "sku", "value": "SKU-DEMO-001", "type": "text" },
                { "key": "category", "value": "Electronics", "type": "text" },
                { "key": "purchasePrice", "value": "10", "type": "text" },
                { "key": "sellingPrice", "value": "20", "type": "text" },
                { "key": "stockQuantity", "value": "25", "type": "text" },
                { "key": "image", "type": "file", "src": "", "description": "Select an image file (required)" }
              ]
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PATCH",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Updated Product Name", "type": "text" },
                { "key": "stockQuantity", "value": "30", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Delete Product (Admin only)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Sales",
      "item": [
        {
          "name": "Create Sale",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('saleId', json.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/sales"
          }
        },
        {
          "name": "Create Sale (Insufficient Stock - should fail)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 99999\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/sales"
          }
        },
        {
          "name": "List Sales",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.data.results && json.data.results.length > 0) {",
                  "        pm.collectionVariables.set('saleId', json.data.results[0]._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/sales?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["sales"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "from", "value": "2024-01-01", "disabled": true },
                { "key": "to", "value": "2026-12-31", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Sale by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/sales/{{saleId}}"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard/stats"
          }
        }
      ]
    },
    {
      "name": "RBAC Tests",
      "description": "Run these after switching login (Employee/Manager) to verify 403 responses",
      "item": [
        {
          "name": "Employee - Create Product (should 403)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Test", "type": "text" },
                { "key": "sku", "value": "SKU-TEST", "type": "text" },
                { "key": "category", "value": "Test", "type": "text" },
                { "key": "purchasePrice", "value": "1", "type": "text" },
                { "key": "sellingPrice", "value": "2", "type": "text" },
                { "key": "stockQuantity", "value": "1", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Manager - Delete Product (should 403)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        }
      ]
    }
  ]
}
